{
  "version": "1.0.0",
  "source": "./index.html",
  "main": "electron/main.cjs",
  "type": "module",
  "name": "uam-control-hub",
  "description": "UAM Control Hub",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve:dist": "node scripts/serve-dist.cjs",
    "electron:preview": "electron .",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win --x64",
    "electron:build:dir": "vite build && electron-builder --win --x64 --dir"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/react-query": "^5.70.0",
    "axios": "^1.8.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "2.1.1",
    "lucide-react": "^0.453.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1",
    "swr": "^2.3.3",
    "tailwind-merge": "2.5.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.1",
    "globals": "15.12.0",
    "serve": "^6.5.8",
    "tailwindcss": "3.4.16",
    "vite": "^6.2.3"
  },
  "alias": {
    "@/*": "./src/components/ui/$1"
  },
  "build": {
    "appId": "com.ttz.uam-control-hub",
    "productName": "UAM Control Hub",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UAM Control Hub"
    }
  }
}
